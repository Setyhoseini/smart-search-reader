{
  "name": "smart-search-reader",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build && shx cp public/service-worker.js dist/",
    "start": "npx serve@latest dist",
    "lint": "next lint",
    "build:sw:generate": "node scripts/generate.js",
    "build:sw": "webpack --config webpack.config.js",
    "release": "npm run build:sw && npm run build && npm run build:sw:generate && npm run build:sw",
    "release:full": "npm run build:sw && npm run build && npm run build:sw:generate && npm run build:sw && shx cp public/service-worker.js dist/"
  },
  "dependencies": {
    "next": "16.2.9",
    "next-pwa": "^5.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "shx": "^0.4.0",
    "tailwindcss": "^4",
    "ts-loader": "^9.6.2",
    "typescript": "^5",
    "webpack": "^5.108.3",
    "webpack-cli": "^7.1.0"
  }
}
